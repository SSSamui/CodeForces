#include <iostream>
#include <cstdio>
#include <cmath>
using namespace std;
using ll = long long;

bool check(ll a, ll b, int p)
{
	while (a > 0)
	{
		ll r = a % b;
		for (int i = 0; i < p; i++)
		{
			if (a % b != r) return false;
			a /= b;
		}
	}

	return true;
}

ll power(ll b, ll e)
{
	if (e == 0) return 1;
	if (e % 2 == 1) return b * power(b, e - 1);
	ll pw = power(b, e / 2);
	pw *= pw;
	return pw;
}

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--)
	{
		ll n;
		cin >> n;
		if (n < 3) cout << "0\n";
		else
		{
			int ans = 1;
			for (int p = 3; p < 40; p++) for (int b = 2; power(b, p - 1) < n; b++) if (check(n, b, p)) ans++;
			for (ll f = 2; f * f <= n; f++) if (n % f == 0)
			{
				if (f > 2) if (check(n, f - 1ll, 2)) ans++;
				if (f * f < n) if (check(n, (n / f) - 1ll, 2)) ans++;
			}

			cout << ans << "\n";
		}	
	}
}
