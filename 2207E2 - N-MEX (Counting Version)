#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
using namespace std;
using ll = long long;

const ll MOD = 1e9 + 7;
const int MXN = 2e5 + 1;

ll fact[MXN];

ll solve()
{
	int n;
	cin >> n;
	vector<int> a(n + 1);
	a[0] = n;
	for (int i = 1; i <= n; i++) cin >> a[i];

	int countb = 0;
	ll ans = 1;
	for (int i = 1; i <= n; i++)
	{
		if (a[i] < n - i) return 0;
		if (a[i] > a[i - 1]) return 0;
		if (a[i] == a[i - 1]) countb++;
		else
		{
			for (int num = a[i - 1] - 1; num > a[i]; num--)
			{
				ans = (ans * countb) % MOD;
				countb--;
			}

			ans = (ans * (n - a[i] + countb)) % MOD;
		}
	}

	for (int num = a[n]; num > 0; num--) ans = (ans * num) % MOD;
	return ans;
}

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--) cout << solve() << "\n";
}
