#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
using namespace std;

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--)
	{
		int n, k;
		cin >> n >> k;
		vector<int> a(n + 2), p(k + 1, 0);
		for (int i = 1; i <= n; i++) cin >> a[i];
		for (int i = 0; i < k; i++) cin >> p[i];
		a[0] = a[p[0]], a[n + 1] = a[p[0]];

		int s = 0, v = 0, curr = 0, ind = 0;
		for (int i = 0; i <= n; i++)
		{
			if (i == p[ind]) ind++, curr = 0;
			if (a[i] != a[i + 1]) curr++, s++;
			if (curr > v) v = curr;
		}

		s /= 2;
		if (s < v) s = v;
		cout << s << "\n";
	}
}
