#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
#include <string>
using namespace std;
using ll = long long;

bool solve()
{
	int n;
	cin >> n;
	string s;
	cin >> s;
	vector<ll> a(n), c(n);
	for (int i = 0; i < n; i++) cin >> a[i];
	for (int i = 0; i < n; i++) cin >> c[i];
	if ((s[0] == '1') && (a[0] != c[0])) return false;
	for (int i = 1; i < n; i++) if (c[i] < c[i - 1]) return false;

	vector<ll> psum = c;
	for (int i = 1; i < n; i++) if (s[i] == '1') psum[i] = min(psum[i], psum[i - 1] + a[i]);
	for (int i = n - 1; i > 0; i--) if (s[i] == '1') psum[i - 1] = min(psum[i - 1], psum[i] - a[i]);

	ll mx = psum[0];
	for (int i = 0; i < n; i++)
	{
		mx = max(mx, psum[i]);
		if (mx != c[i]) return false;
	}

	for (int i = n - 1; i > 0; i--) psum[i] -= psum[i - 1];
	cout << "Yes\n";
	for (int i = 0; i < n; i++) cout << psum[i] << ' ';
	cout << "\n";
	return true;
}

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--) if (!solve()) cout << "No\n";
}
