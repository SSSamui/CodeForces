#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
using namespace std;

struct tree
{
	int n;
	vector<vector<int>> adj;
	int last;

	tree()
	{
		cin >> n;
		adj = vector<vector<int>>(n + 1, vector<int>(0));
		last = 0;
		for (int i = 1; i < n; i++)
		{
			int a, b;
			cin >> a >> b;
			adj[a].push_back(b), adj[b].push_back(a);
		}
	}

	bool dfs(int node = 1, int p = 0)
	{
		if (last == 0) last = node;
		else
		{
			cout << "? " << last << ' ' << node << "\n";
			cout.flush();

			int q;
			cin >> q;
			if (q == 0) last = 0;
			else
			{
				cout << "? " << last << ' ' << last << "\n";
				cout.flush();

				cin >> q;
				if (q == 0) cout << "! " << node << "\n";
				else cout << "! " << last << "\n";
				cout.flush();

				return true;
			}
		}

		for (int nxt : adj[node]) if (nxt != p) if (dfs(nxt, node)) return true;
		return false;
	}
};

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--)
	{
		tree Tree = tree();
		if (!Tree.dfs())
		{
			cout << "! " << Tree.last << "\n";
			cout.flush();
		}
	}
}
