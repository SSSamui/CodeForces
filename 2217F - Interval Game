#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
using namespace std;
using ll = long long;

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	int _;
	cin >> _;
	while (_--)
	{
		int x1, x2;
		cin >> x1 >> x2;

		if (x1 > x2) cout << "1 1\n";
		else
		{
			int fxor = 0, count = (x2 + 1) / 2;

			for (int i = 1; i < x1; i++)
			{
				int M = (x2 - 1 - i) / 2;
				vector<int> bits(0);
				for (int j = 0; j < 19; j++) if (i & (1 << j)) bits.push_back(j);
				for (int j = bits.size() - 1; j > -1; j--)
				{
					if (M & (1 << bits[j])) M |= ((1 << bits[j]) - 1);
					M = ((M % (1 << bits[j])) + ((M / (1 << (bits[j] + 1))) << bits[j]));
				}

				M++;
				M = (M << bits.size());
				if (M < count) fxor = i, count = M;
			}

			cout << "1 " << (x1 - fxor) << "\n";
		}
	}
}
