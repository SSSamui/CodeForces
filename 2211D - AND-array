#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
using namespace std;
using ll = long long;

const ll MOD = 1e9 + 7;
const int MX = 1e5 + 1;

ll fact[MX], inv[MX];

ll pw(ll b, ll e)
{
	if (e == 0) return 1;
	if (e % 2 == 1) return (pw(b, e - 1) * b) % MOD;
	ll ans = pw(b, e / 2);
	return (ans * ans) % MOD;
}

ll choose(ll a, ll b)
{
	return ((((fact[a] * inv[b]) % MOD) * inv[a - b]) % MOD);
}

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	fact[0] = 1;
	for (int i = 1; i < MX; i++) fact[i] = (fact[i - 1] * i) % MOD;
	inv[MX - 1] = pw(fact[MX - 1], MOD - 2);
	for (int i = MX - 2; i >= 0; i--) inv[i] = (inv[i + 1] * (i + 1)) % MOD;

	int _;
	cin >> _;
	while (_--)
	{
		int n;
		cin >> n;
		vector<int> b(n + 1);
		for (int i = 1; i <= n; i++) cin >> b[i];

		vector<int> a(n, 0);
		for (int i = n; i > 0; i--) for (int j = 0; j < 29; j++) if (b[i] & (1 << j))
		{
			for (int k = 0; k < i; k++) a[k] += (1 << j);
			for (int k = 1; k <= i; k++) b[k] = (b[k] - ((choose(i, k) << j) % MOD) + MOD) % MOD;
		}

		for (int i = 0; i < n; i++) cout << a[i] << ' ';
		cout << "\n";
	}
}
